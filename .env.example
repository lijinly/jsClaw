# ── LLM Provider 选择 ──────────────────────────────────────────────────────
# 可选值: qwen | openai | deepseek | moonshot | ollama
LLM_PROVIDER=qwen

# ── API Key ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here

# ── 模型名称（留空则使用 Provider 默认值）──────────────────────────────────
# 千问可选: qwen-turbo / qwen-plus / qwen-max / qwen-long / qwen2.5-72b-instruct
# OpenAI可选: gpt-4o-mini / gpt-4o / gpt-3.5-turbo
MODEL_NAME=qwen-plus

# ── 自定义 BaseURL（可选，留空则使用 Provider 预设）────────────────────────
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
