# ── LLM Provider 选择 ──────────────────────────────────────────────────────
# 可选值: qwen | openai | deepseek | moonshot | ollama
LLM_PROVIDER=qwen

# ── API Key 配置 ────────────────────────────────────────────────────────────
# 重要：为了安全性，API Key 不存储在 .env 文件中
# 请将 API Key 设置为系统环境变量 OPENAI_API_KEY
#
# 配置方法：
#
# Windows (PowerShell):
#   $env:OPENAI_API_KEY = "your_api_key_here"
#
# Windows (CMD):
#   set OPENAI_API_KEY=your_api_key_here
#
# macOS / Linux (bash/zsh):
#   export OPENAI_API_KEY=your_api_key_here
#
# 永久配置（Windows）：
#   1. 右键 "此电脑" → 属性 → 高级系统设置
#   2. 环境变量 → 新建 → OPENAI_API_KEY = your_key

# 千问可选模型：qwen-plus / qwen-max / qwen-turbo / qwen-long / qwen2.5-72b-instruct
MODEL_NAME=qwen-plus

# ── 自定义 BaseURL（可选，留空则使用 Provider 预设）────────────────────────
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

